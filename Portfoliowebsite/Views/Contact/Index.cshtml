@{
    ViewData["Title"] = "Contact";
}

<h1>Contact</h1>

<form id="contactForm" asp-action="Index" method="post" novalidate>
    @Html.AntiForgeryToken()

    <p class="hp">
        <label for="website">Laat dit veld leeg</label>
        <input type="text" id="website" name="website" value="" />
    </p>

    <p>
        <label for="Name">Naam</label>
        <input id="Name" name="Name" placeholder="Naam" />
        <span id="nameErr" class="error" role="alert" aria-live="polite"></span>
    </p>

    <p>
        <label for="Email">E-mail</label>
        <input id="Email" name="Email" placeholder="naam@domein.nl" />
        <span id="emailErr" class="error" role="alert" aria-live="polite"></span>
    </p>

    <p>
        <label for="Subject">Onderwerp</label>
        <input id="Subject" name="Subject" placeholder="Onderwerp" />
    </p>

    <p>
        <label for="Message">Bericht</label>
        <textarea id="Message" name="Message" rows="5" placeholder="Je bericht"></textarea>
        <span id="msgErr" class="error" role="alert" aria-live="polite"></span>
    </p>

    <p id="liveStatus" aria-live="polite"></p>
    <button type="submit" class="send-button">Versturen</button>
</form>