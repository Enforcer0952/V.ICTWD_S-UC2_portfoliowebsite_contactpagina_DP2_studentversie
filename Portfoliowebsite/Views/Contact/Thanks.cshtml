@model Portfoliowebsite.Models.ContactViewModel

@{
    ViewData["Title"] = "Bedankt";
}

<h1>Bedankt!</h1>

<p>Bedankt, @Model.Name. We nemen contact op via @Model.Email.</p>
<p>Je onderwerp: @Model.Subject</p>
<p>Je bericht:</p>
<div class="message-preview">@Model.Message</div>

<a href="/contact">Terug naar formulier</a>